{
  "name": "babylonjs",
  "version": "1.0.0",
  "description": "Testing Babylong JS",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "esbuild src/main.ts --bundle --outfile=dist/main.js",
    "build:watch": "esbuild src/main.ts --bundle --outfile=dist/main.js --watch",
    "live-server": "live-server --port=8080 --no-browser --watch=dist,index.html",
    "start": "npm-run-all --parallel build:watch live-server"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.12",
    "esbuild": "^0.21.4",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@babylonjs/core": "^7.9.0",
    "@babylonjs/materials": "^7.9.0"
  }
}
